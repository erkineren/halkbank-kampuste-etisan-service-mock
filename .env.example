PORT=3000
HOST=0.0.0.0
# true = aynı (TCKN, KART_ID) için EKLE/IPTAL durum tutar
# false = her REZERVASYONLAR çağrısında default fixture döner
STATEFUL=true
# Kampüs Giriş QR (KampusGirisQrCode) için ChaCha private key — tek sabit key.
# Default, entegrasyon rehberindeki örnek key'dir (bilinen test vektörü ile uyumlu).
QR_PRIVATE_KEY=0x00000052,0x11221111,0x12345678,0x12345678,0x15645678,0x12345678,0xAAAAAA23,0xFFFFFFDD
